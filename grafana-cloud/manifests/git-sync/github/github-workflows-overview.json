                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-github-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "cfq4tb1lcmarkd"
                      },
                      "spec": {
                        "app": "grafana-assistant-app",
                        "options": {
                          "workflow": "$workflow"
                        },
                        "owner": "$owner",
                        "queryType": "Workflow_Runs",
                        "range": true,
                        "repository": "$repo"
                      }

{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "github-workflows-overview"
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "builtIn": true,
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations \u0026 Alerts",
          "query": {
            "datasource": {
              "name": "-- Grafana --"
            },
            "group": "grafana",
            "kind": "DataQuery",
            "spec": {},
            "version": "v0"
          }
        }
      }
    ],
    "cursorSync": "Off",
    "description": "Workflow run history, result distribution, and success/failure rates per repository for the $owner GitHub org.",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "cfq4tb1lcmarkd"
                      },
                      "group": "grafana-github-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "app": "grafana-assistant-app",
                        "options": {
                          "workflow": "$workflow"
                        },
                        "owner": "$owner",
                        "queryType": "Workflow_Runs",
                        "range": true,
                        "repository": "$repo"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "group": "filterByValue",
                  "kind": "Transformation",
                  "spec": {
                    "disabled": false,
                    "options": {
                      "filters": [
                        {
                          "config": {
                            "id": "regex",
                            "options": {
                              "value": "${branch}"
                            }
                          },
                          "fieldName": "head_branch"
                        }
                      ],
                      "match": "any",
                      "type": "include"
                    }
                  }
                },
                {
                  "group": "filterFieldsByName",
                  "kind": "Transformation",
                  "spec": {
                    "disabled": false,
                    "options": {
                      "include": {
                        "pattern": "^(created_at|head_branch|conclusion)$"
                      }
                    }
                  }
                },
                {
                  "group": "partitionByValues",
                  "kind": "Transformation",
                  "spec": {
                    "disabled": false,
                    "options": {
                      "fields": [
                        "head_branch"
                      ],
                      "keepFields": false
                    }
                  }
                }
              ]
            }
          },
          "description": "",
          "id": 1,
          "links": [],
          "title": "Workflow Run History",
          "vizConfig": {
            "group": "state-timeline",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "continuous-GrYlRd"
                  },
                  "custom": {
                    "axisPlacement": "auto",
                    "fillOpacity": 70,
                    "hideFrom": {
                      "legend": false,
                      "tooltip": false,
                      "viz": false
                    },
                    "insertNulls": false,
                    "lineWidth": 0,
                    "spanNulls": false
                  },
                  "displayName": "${__field.labels.head_branch}",
                  "mappings": [
                    {
                      "options": {
                        "cancelled": {
                          "color": "text",
                          "index": 2,
                          "text": "cancelled"
                        },
                        "failure": {
                          "color": "red",
                          "index": 1,
                          "text": "failure"
                        },
                        "skipped": {
                          "color": "semi-dark-blue",
                          "index": 3,
                          "text": "skipped"
                        },
                        "success": {
                          "color": "green",
                          "index": 0,
                          "text": "success"
                        },
                        "timed_out": {
                          "color": "orange",
                          "index": 4,
                          "text": "timed_out"
                        }
                      },
                      "type": "value"
                    }
                  ],
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      },
                      {
                        "color": "red",
                        "value": 80
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "alignValue": "left",
                "annotations": {
                  "clustering": -1,
                  "multiLane": false
                },
                "legend": {
                  "displayMode": "list",
                  "overflow": "ellipsis",
                  "placement": "bottom",
                  "showLegend": true
                },
                "mergeValues": true,
                "rowHeight": 0.9,
                "showValue": "auto",
                "tooltip": {
                  "hideZeros": false,
                  "mode": "single",
                  "sort": "none"
                }
              }
            },
            "version": "13.1.0-27942650397"
          }
        }
      },
      "panel-3": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": true,
                    "query": {
                      "datasource": {
                        "name": "cfq4tb1lcmarkd"
                      },
                      "group": "grafana-github-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "app": "grafana-assistant-app",
                        "options": {
                          "workflow": "$workflow"
                        },
                        "owner": "$owner",
                        "queryType": "Workflow_Runs",
                        "range": true,
                        "repository": "$repo"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "__expr__"
                      },
                      "group": "__expr__",
                      "kind": "DataQuery",
                      "spec": {
                        "app": "grafana-assistant-app",
                        "expression": "SELECT head_branch, ROUND(100.0 * SUM(CASE WHEN conclusion = 'success' THEN 1 ELSE 0 END) / COUNT(*), 1) AS success_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'failure' THEN 1 ELSE 0 END) / COUNT(*), 1) AS failure_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'cancelled' THEN 1 ELSE 0 END) / COUNT(*), 1) AS cancelled_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'timed_out' THEN 1 ELSE 0 END) / COUNT(*), 1) AS timed_out_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'skipped' THEN 1 ELSE 0 END) / COUNT(*), 1) AS skipped_pct, COUNT(*) AS total, ROUND(AVG(CASE WHEN status = 'completed' THEN TIMESTAMPDIFF(SECOND, run_started_at, updated_at) END), 1) AS avg_duration_s FROM A WHERE head_branch LIKE '${branch}' GROUP BY head_branch ORDER BY total DESC LIMIT 100",
                        "type": "sql"
                      },
                      "version": "v0"
                    },
                    "refId": "B"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 3,
          "links": [],
          "title": "Result Rates",
          "vizConfig": {
            "group": "table",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "custom": {
                    "align": "auto",
                    "cellOptions": {
                      "type": "auto"
                    },
                    "footer": {
                      "reducers": []
                    },
                    "inspect": false
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      }
                    ]
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "head_branch"
                    },
                    "properties": [
                      {
                        "id": "displayName",
                        "value": "Branch"
                      },
                      {
                        "id": "custom.width",
                        "value": 160
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "success_pct"
                    },
                    "properties": [
                      {
                        "id": "custom.cellOptions",
                        "value": {
                          "mode": "basic",
                          "type": "gauge"
                        }
                      },
                      {
                        "id": "min",
                        "value": 0
                      },
                      {
                        "id": "max",
                        "value": 100
                      },
                      {
                        "id": "unit",
                        "value": "percent"
                      },
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "green",
                          "mode": "fixed"
                        }
                      },
                      {
                        "id": "displayName",
                        "value": "Success %"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "failure_pct"
                    },
                    "properties": [
                      {
                        "id": "custom.cellOptions",
                        "value": {
                          "mode": "basic",
                          "type": "gauge"
                        }
                      },
                      {
                        "id": "min",
                        "value": 0
                      },
                      {
                        "id": "max",
                        "value": 100
                      },
                      {
                        "id": "unit",
                        "value": "percent"
                      },
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "red",
                          "mode": "fixed"
                        }
                      },
                      {
                        "id": "displayName",
                        "value": "Failure %"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "cancelled_pct"
                    },
                    "properties": [
                      {
                        "id": "custom.cellOptions",
                        "value": {
                          "mode": "basic",
                          "type": "gauge"
                        }
                      },
                      {
                        "id": "min",
                        "value": 0
                      },
                      {
                        "id": "max",
                        "value": 100
                      },
                      {
                        "id": "unit",
                        "value": "percent"
                      },
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "text",
                          "mode": "fixed"
                        }
                      },
                      {
                        "id": "displayName",
                        "value": "Cancelled %"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "timed_out_pct"
                    },
                    "properties": [
                      {
                        "id": "custom.cellOptions",
                        "value": {
                          "mode": "basic",
                          "type": "gauge"
                        }
                      },
                      {
                        "id": "min",
                        "value": 0
                      },
                      {
                        "id": "max",
                        "value": 100
                      },
                      {
                        "id": "unit",
                        "value": "percent"
                      },
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "orange",
                          "mode": "fixed"
                        }
                      },
                      {
                        "id": "displayName",
                        "value": "Timed Out %"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "skipped_pct"
                    },
                    "properties": [
                      {
                        "id": "custom.cellOptions",
                        "value": {
                          "mode": "basic",
                          "type": "gauge"
                        }
                      },
                      {
                        "id": "min",
                        "value": 0
                      },
                      {
                        "id": "max",
                        "value": 100
                      },
                      {
                        "id": "unit",
                        "value": "percent"
                      },
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "semi-dark-blue",
                          "mode": "fixed"
                        }
                      },
                      {
                        "id": "displayName",
                        "value": "Skipped %"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "total"
                    },
                    "properties": [
                      {
                        "id": "custom.width",
                        "value": 60
                      },
                      {
                        "id": "displayName",
                        "value": "Total"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "avg_duration_s"
                    },
                    "properties": [
                      {
                        "id": "custom.cellOptions",
                        "value": {
                          "mode": "basic",
                          "type": "gauge"
                        }
                      },
                      {
                        "id": "max",
                        "value": 600
                      },
                      {
                        "id": "unit",
                        "value": "s"
                      },
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "blue",
                          "mode": "fixed"
                        }
                      },
                      {
                        "id": "displayName",
                        "value": "Avg Duration"
                      }
                    ]
                  }
                ]
              },
              "options": {
                "cellHeight": "sm",
                "showHeader": true,
                "sortBy": [
                  {
                    "desc": true,
                    "displayName": "total"
                  }
                ]
              }
            },
            "version": "13.1.0-27942650397"
          }
        }
      }
    },
    "layout": {

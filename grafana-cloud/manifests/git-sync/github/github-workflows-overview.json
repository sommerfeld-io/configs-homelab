  "cursorSync": "Off",
  "description": "Overview of GitHub Actions workflow runs across repositories — status distribution and run history.",
  "editable": true,
  "elements": {
    "panel-3": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "cfq4tb1lcmarkd"
                    },
                    "group": "grafana-github-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "app": "grafana-assistant-app",
                      "options": {
                        "workflow": "$workflow"
                      },
                      "owner": "$owner",
                      "queryType": "Workflow_Runs",
                      "range": true,
                      "repository": "$repo"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": [
              {
                "group": "filterByValue",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "filters": [
                      {
                        "config": {
                          "id": "regex",
                          "options": {
                            "value": "$branch"
                          }
                        },
                        "fieldName": "head_branch"
                      }
                    ],
                    "match": "any",
                    "type": "include"
                  }
                }
              },
              {
                "group": "groupBy",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "fields": {
                      "conclusion": {
                        "aggregations": [
                          "count"
                        ],
                        "operation": "groupby"
                      }
                    }
                  }
                }
              },
              {
                "group": "organize",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "renameByName": {
                      "conclusion": "Result",
                      "conclusion (count)": "Count"
                    }
                  }
                }
              },
              {
                "group": "rowsToFields",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "nameField": "Result",
                    "valueField": "Count"
                  }
                }
              }
            ]
          }
        },
        "description": "Percentage breakdown of all workflow run conclusions (success, failure, cancelled, skipped, etc.).",
        "id": 3,
        "links": [],
        "title": "Result Distribution",
        "vizConfig": {
          "group": "piechart",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "color": {
                  "fixedColor": "#73BF69",
                  "mode": "palette-classic"
                },
                "custom": {
                  "hideFrom": {
                    "legend": false,
                    "tooltip": false,
                    "viz": false
                  }
                },
                "mappings": [
                  {
                    "options": {
                      "cancelled": {
                        "color": "text",
                        "index": 0
                      },
                      "failure": {
                        "color": "red",
                        "index": 1
                      },
                      "skipped": {
                        "color": "blue",
                        "index": 2
                      },
                      "success": {
                        "color": "green",
                        "index": 3
                      },
                      "timed_out": {
                        "color": "purple",
                        "index": 4
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              "overrides": [
                {
                  "matcher": {
                    "id": "byName",
                    "options": "success"
                  },
                  "properties": [
                    {
                      "id": "color",
                      "value": {
                        "fixedColor": "green",
                        "mode": "fixed"
                      }
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "failure"
                  },
                  "properties": [
                    {
                      "id": "color",
                      "value": {
                        "fixedColor": "red",
                        "mode": "fixed"
                      }
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "cancelled"
                  },
                  "properties": [
                    {
                      "id": "color",
                      "value": {
                        "fixedColor": "text",
                        "mode": "fixed"
                      }
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "skipped"
                  },
                  "properties": [
                    {
                      "id": "color",
                      "value": {
                        "fixedColor": "blue",
                        "mode": "fixed"
                      }
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "timed_out"
                  },
                  "properties": [
                    {
                      "id": "color",
                      "value": {
                        "fixedColor": "orange",
                        "mode": "fixed"
                      }
                    }
                  ]
                }
              ]
            },
            "options": {
              "displayLabels": [
                "name",
                "percent"
              ],
              "legend": {
                "displayMode": "table",
                "placement": "right",
                "showLegend": true,
                "values": [
                  "percent",
                  "value"
                ]
              },
              "pieType": "donut",
              "reduceOptions": {
                "calcs": [
                  "lastNotNull"
                ],
                "fields": "",
                "values": false
              },
              "sort": "desc",
              "tooltip": {
                "hideZeros": false,
                "mode": "multi",
                "sort": "desc"
              }
            }
          },
          "version": "13.1.0-27822252871"
        }
      }
    },

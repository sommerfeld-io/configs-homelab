                    "refId": "A",
                    "hidden": true
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "__expr__",
                      "version": "v0",
                      "datasource": {
                        "name": "__expr__"
                      },
                      "spec": {
                        "app": "grafana-assistant-app",
                        "expression": "SELECT head_branch, ROUND(100.0 * SUM(CASE WHEN conclusion = 'success' THEN 1 ELSE 0 END) / COUNT(*), 1) AS success_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'failure' THEN 1 ELSE 0 END) / COUNT(*), 1) AS failure_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'cancelled' THEN 1 ELSE 0 END) / COUNT(*), 1) AS cancelled_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'timed_out' THEN 1 ELSE 0 END) / COUNT(*), 1) AS timed_out_pct, ROUND(100.0 * SUM(CASE WHEN conclusion = 'skipped' THEN 1 ELSE 0 END) / COUNT(*), 1) AS skipped_pct, COUNT(*) AS total, ROUND(AVG(CASE WHEN status = 'completed' THEN TIMESTAMPDIFF(SECOND, run_started_at, updated_at) END), 1) AS avg_duration_s FROM A GROUP BY head_branch ORDER BY total DESC LIMIT 100",
                        "type": "sql"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                }
              ],
              "transformations": [
                {
                  "kind": "Transformation",
                  "group": "filterByValue",
                  "spec": {
                    "options": {

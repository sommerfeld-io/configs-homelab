{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Workflow run history and status for a single repository. Scope using the Organisation, Repository, and Git Ref dropdowns. Default view: last 7 days across all refs.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "description": "One row per unique workflow run, coloured by result. Each block is a single run — click to open it in GitHub.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "axisPlacement": "auto",
            "fillOpacity": 70,
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineWidth": 0,
            "spanNulls": false
          },
          "links": [
            {
              "targetBlank": true,
              "title": "Open in GitHub",
              "url": "https://github.com/${__field.labels.org}/${__field.labels.repo}/actions/runs/${__field.labels.run_id}"
            }
          ],
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "index": 0,
                  "text": "Success"
                },
                "2": {
                  "color": "red",
                  "index": 1,
                  "text": "Failure"
                },
                "3": {
                  "color": "#555555",
                  "index": 2,
                  "text": "Cancelled"
                },
                "4": {
                  "color": "#aaaaaa",
                  "index": 3,
                  "text": "Skipped"
                }
              },
              "type": "value"
            }
          ],
          "noValue": "No workflow runs found for this repository and ref selection.",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "alignValue": "left",
        "annotations": {
          "clustering": -1,
          "multiLane": false
        },
        "colWidth": 0.9,
        "fillOpacity": 90,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "mergeValues": false,
        "rowHeight": 0.8,
        "showValue": "always",
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "13.1.0-27822252871",
      "targets": [
        {
          "app": "grafana-assistant-app",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "(last_over_time(github_workflow_run{org=\"$org\",repo=\"$repo\",git_ref=~\"$git_ref\",result=\"success\"}[1m]) * 0 + 1) or (last_over_time(github_workflow_run{org=\"$org\",repo=\"$repo\",git_ref=~\"$git_ref\",result=\"failure\"}[1m]) * 0 + 2) or (last_over_time(github_workflow_run{org=\"$org\",repo=\"$repo\",git_ref=~\"$git_ref\",result=\"cancelled\"}[1m]) * 0 + 3) or (last_over_time(github_workflow_run{org=\"$org\",repo=\"$repo\",git_ref=~\"$git_ref\",result=\"skipped\"}[1m]) * 0 + 4)",
          "instant": false,
          "legendFormat": "{{workflow}} · {{workflow_file}}",
          "queryType": "range",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Workflow Runs",
      "type": "state-timeline"
    }
  ],
  "preload": false,
  "refresh": "",
  "schemaVersion": 42,
  "templating": {
    "list": [
      {

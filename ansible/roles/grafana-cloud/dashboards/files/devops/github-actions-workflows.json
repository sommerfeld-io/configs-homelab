            }
          ],
          "metric": "github_workflow_run",
          "qryType": 1,
          "query": "label_values(github_workflow_run{org=\"$org\",repo=\"$repo\"},git_ref)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,

{
    "name": "configs-homelab",
    "build": {
        "dockerfile": "Dockerfile"
    },

    "customizations": {
        "vscode": {
            "settings": {},
            "extensions": [
                "streetsidesoftware.code-spell-checker",
                "asciidoctor.asciidoctor-vscode",
                "ms-azuretools.vscode-containers",
                "aaron-bond.better-comments",
                "timonwong.shellcheck",
                "jebbs.plantuml",
                "github.vscode-github-actions",
                "redhat.vscode-yaml",
                "GitHub.copilot",
                "Grafana.grafana-alloy",
                "DavidAnson.vscode-markdownlint",
                "EditorConfig.EditorConfig",
                "tamasfe.even-better-toml",
                "task.vscode-task"
            ]
        }
    },

    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2.12.0": {},
        "ghcr.io/devcontainers/features/node:1": {
          "version": "latest"
        }
    },

    "containerEnv": {
      "SONARCLOUD_TOKEN": "${localEnv:SONARCLOUD_TOKEN}"
    },

    "postCreateCommand": "${containerWorkspaceFolder}/.devcontainer/post-create.sh",
    "postStartCommand": "${containerWorkspaceFolder}/.devcontainer/post-start.sh"
}
